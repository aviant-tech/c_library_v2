<?xml version="1.0"?>
<mavlink>
  <!-- Complete message set for use on Aviant UAS  -->
  <!-- https://github.com/aviant/mavlink           -->
  <!-- mavlink ID range: 59000 - 59099             -->
  <include>development.xml</include>
  <include>common.xml</include>
  <include>AVSSUAS.xml</include>
  <include>ardupilotmega.xml</include>
  <version>0</version>
  <dialect>0</dialect>
  <enums>
    <enum name="AVIANT_STATE">
      <description>Aviant system state</description>
      <entry name="UNSPECIFIED" value="0"/>
    </enum>
    <enum name="AVIANT_INDICATOR_STATE">
      <description>Display state for Aviant indicators</description>
      <entry name="AVIANT_INDICATOR_STATE_INACTIVE" value="0"/>
      <entry name="AVIANT_INDICATOR_STATE_NOMINAL" value="1"/>
      <entry name="AVIANT_INDICATOR_STATE_WARNING" value="2"/>
      <entry name="AVIANT_INDICATOR_STATE_CRITICAL" value="3"/>
    </enum>
    <enum name="AVIANT_NAV_REDUNDANCY">
      <description>Navigation redundancy state</description>
      <entry name="AVIANT_NAV_REDUNDANCY_UNKNOWN" value="0"/>
      <entry name="AVIANT_NAV_REDUNDANCY_REDUNDANT" value="1"/>
      <entry name="AVIANT_NAV_REDUNDANCY_SINGLE" value="2"/>
      <entry name="AVIANT_NAV_REDUNDANCY_FAILED" value="3"/>
    </enum>
    <enum name="AVIANT_NAV_ACCURACY">
      <description>Navigation accuracy state</description>
      <entry name="AVIANT_NAV_ACCURACY_UNKNOWN" value="0"/>
      <entry name="AVIANT_NAV_ACCURACY_ACCURATE" value="1"/>
      <entry name="AVIANT_NAV_ACCURACY_APPROXIMATE" value="2"/>
      <entry name="AVIANT_NAV_ACCURACY_FAILED" value="3"/>
    </enum>
    <enum name="AVIANT_ATS_STATUS_FLAG">
      <description>ATS status flags</description>
      <entry name="AVIANT_ATS_STATUS_FLAG_ACCEL_NORM_FAIL" value="1"/>
      <entry name="AVIANT_ATS_STATUS_FLAG_ROLL_FAIL" value="2"/>
      <entry name="AVIANT_ATS_STATUS_FLAG_PITCH_FAIL" value="4"/>
      <entry name="AVIANT_ATS_STATUS_FLAG_FC_TIMEOUT" value="8"/>
      <entry name="AVIANT_ATS_STATUS_FLAG_POWER_LOSS" value="16"/>
      <entry name="AVIANT_ATS_STATUS_FLAG_REBOOTED_WHILE_ARMED" value="32"/>
      <entry name="AVIANT_ATS_STATUS_FLAG_PARACHUTE_DEPLOY" value="64"/>
      <entry name="AVIANT_ATS_STATUS_FLAG_UPS_UNHEALTHY" value="128"/>
    </enum>
  </enums>
  <messages>
    <message name="AVIANT_HEARTBEAT" id="59000">
      <description>Shows that a system is running Aviant protocol</description>
      <field name="state" type="uint8_t" enum="AVIANT_STATE">Current state of the system/component</field>
    </message>
    <message name="AVIANT_INDICATOR_DUMMY" id="59001">
      <description>Dummy message for testing Aviant indicators</description>
      <field name="state" type="uint8_t" enum="AVIANT_INDICATOR_STATE"/>
      <field name="float_value" type="float"/>
      <field name="float_array" type="float[4]"/>
      <field name="uint8_value" type="uint8_t"/>
      <field name="int32_value" type="int32_t"/>
      <field name="text_value" type="char[8]"/>
    </message>
    <message name="AVIANT_NAV" id="59002">
      <description>Navigation indicators</description>
      <field name="accuracy" type="uint8_t" enum="AVIANT_NAV_ACCURACY">Absolute position accuracy</field>
      <field name="redundancy" type="uint8_t" enum="AVIANT_NAV_REDUNDANCY">Navigation sensor redundancy</field>
    </message>
    <message name="AVIANT_INDICATOR_MOTORS" id="59003">
      <description>Motor status indicators</description>
      <field name="mot_voltage_cv" type="int16_t[12]" units="cV">Motor voltages in centivolt</field>
      <field name="mot_load_status" type="uint8_t[12]" enum="AVIANT_INDICATOR_STATE">Motor load status per motor</field>
      <field name="anomalous_current_ca" type="int16_t" units="cA">Anomalous current in centiamps</field>
      <field name="anomalous_current_status" type="uint8_t" enum="AVIANT_INDICATOR_STATE">Anomalous current status</field>
    </message>
    <message name="AVIANT_INDICATOR_FW_ICING" id="59004">
      <description>Icing indicator</description>
      <field name="state" type="uint8_t" enum="AVIANT_INDICATOR_STATE">Icing severity</field>
    </message>
    <message name="AVIANT_INDICATOR_TEMP_LOGGER" id="59005">
      <description>Logger temperature indicators</description>
      <field name="pi_internal_state" type="uint8_t" enum="AVIANT_INDICATOR_STATE">Pi internal temperature status</field>
      <field name="pi_internal" type="int8_t" units="degC">Pi internal temperature</field>
      <field name="avionics_ambient_state" type="uint8_t" enum="AVIANT_INDICATOR_STATE">Avionics ambient temperature status</field>
      <field name="avionics_ambient" type="int8_t" units="degC">Avionics ambient temperature</field>
      <field name="fuselage_ambient_state" type="uint8_t" enum="AVIANT_INDICATOR_STATE">Fuselage ambient temperature status</field>
      <field name="fuselage_ambient" type="int8_t" units="degC">Fuselage ambient temperature</field>
      <field name="outside_ambient_state" type="uint8_t" enum="AVIANT_INDICATOR_STATE">Outside ambient temperature status</field>
      <field name="outside_ambient" type="int8_t" units="degC">Outside ambient temperature</field>
      <field name="modem_internal_state" type="uint8_t" enum="AVIANT_INDICATOR_STATE">Modem internal temperature status</field>
      <field name="modem_internal" type="int8_t" units="degC">Modem internal temperature</field>
    </message>
    <message name="AVIANT_INDICATOR_TEMP_FC" id="59006">
      <description>Flight controller temperature indicators</description>
      <field name="battery_internal_state" type="uint8_t" enum="AVIANT_INDICATOR_STATE">Battery internal temperature status</field>
      <field name="battery_internal" type="int8_t" units="degC">Battery internal temperature</field>
      <field name="airspeed_internal_state" type="uint8_t" enum="AVIANT_INDICATOR_STATE">Airspeed sensor internal temperature status</field>
      <field name="airspeed_internal" type="int8_t" units="degC">Airspeed sensor internal temperature</field>
      <field name="imu_internal_state" type="uint8_t" enum="AVIANT_INDICATOR_STATE">IMU internal temperature status</field>
      <field name="imu_internal" type="int8_t" units="degC">IMU internal temperature</field>
      <field name="baro_internal_state" type="uint8_t" enum="AVIANT_INDICATOR_STATE">Barometer internal temperature status</field>
      <field name="baro_internal" type="int8_t" units="degC">Barometer internal temperature</field>
    </message>
    <message name="AVIANT_INDICATOR_C2_LINK" id="59007">
      <description>C2 link quality indicators</description>
      <field name="state" type="uint8_t" enum="AVIANT_INDICATOR_STATE">Overall C2 link status</field>
      <field name="rsrp_dbm" type="int16_t" units="dBm">Reference Signal Received Power</field>
      <field name="rsrq_db" type="int8_t" units="dB">Reference Signal Received Quality</field>
      <field name="sinr_db" type="int8_t" units="dB">Signal to Interference plus Noise Ratio</field>
      <field name="default_interface" type="char[16]">Default network interface name</field>
      <field name="operator_name" type="char[16]">Network operator name</field>
      <field name="freq_band" type="uint8_t">LTE frequency band indicator</field>
      <field name="bytes_sent" type="uint32_t" units="bytes">Cumulative bytes sent</field>
      <field name="bytes_recv" type="uint32_t" units="bytes">Cumulative bytes received</field>
    </message>
    <!-- I left some room for more indicator messages here, so they can get consecutive IDs -->
    <message name="AVIANT_DETAILED_FC_STATE" id="59025">
      <description>Detailed flight controller state</description>
      <field type="uint32_t" name="time_boot_ms" units="ms">Timestamp (time since system boot).</field>
      <field type="uint64_t" name="time_unix_usec" units="us">Timestamp (UNIX epoch time).</field>
      <field type="uint8_t" name="armed" enum="MAV_BOOL">Is the aircraft armed?</field>
      <field type="uint8_t" name="flight_termination" enum="MAV_BOOL">Is the aircraft in flight termination?</field>
    </message>
    <message name="AVIANT_ATS_STATUS" id="59026">
      <description>ATS status. Intended to match the AviantAts.msg uorb message, but using a bitmask instead of bools</description>
      <field type="uint32_t" name="time_boot_ms" units="ms">Timestamp (time since system boot).</field>
      <field type="uint8_t" name="fc_armed" enum="MAV_BOOL">Is the flight controller armed?</field>
      <field type="uint8_t" name="fc_flight_termination" enum="MAV_BOOL">Is the flight controller in flight termination?</field>
      <field type="uint32_t" name="ats_status_flags" enum="AVIANT_ATS_STATUS_FLAG">ATS Status flags</field>
      <field type="uint8_t" name="power_loss_trigger_enabled" enum="MAV_BOOL">Power loss trigger enabled</field>
      <field type="uint8_t" name="ats_enabled" enum="MAV_BOOL">ATS enabled</field>
      <field type="float" name="main_voltage1" units="V">Main voltage measurement 1</field>
      <field type="float" name="main_voltage2" units="V">Main voltage measurement 2</field>
      <field type="float" name="ups_voltage" units="V">UPS voltage measurement</field>
    </message>
  </messages>
</mavlink>
